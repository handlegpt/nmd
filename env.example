# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redirect URIs for OAuth
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://nomad.now/auth/callback

# Supabase Configuration (for production)
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# App Configuration
EXPO_PUBLIC_APP_NAME=NomadNow
EXPO_PUBLIC_APP_DOMAIN=nomad.now
EXPO_PUBLIC_APP_VERSION=1.0.0

# Production Settings
NODE_ENV=production
EXPO_WEB_PORT=19006

# Debug Settings (optional)
EXPO_DEBUG=false

# Email Service Configuration (for verification emails)
# Resend Configuration (recommended)
EXPO_PUBLIC_RESEND_API_KEY=your-resend-api-key
EXPO_PUBLIC_RESEND_FROM=noreply@nomad.now
EXPO_PUBLIC_FROM_NAME=NomadNow

# Alternative: EmailJS Configuration (for frontend email sending)
EXPO_PUBLIC_EMAILJS_SERVICE_ID=your-emailjs-service-id
EXPO_PUBLIC_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
EXPO_PUBLIC_EMAILJS_USER_ID=your-emailjs-user-id

# Production Mode Only
# This application requires Supabase configuration to run
# No mock mode available - configure Supabase credentials above 